<!DOCTYPE html>
<html>
<head>
  <title>Dan Vokey's Plumbing Services</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="page">
    <div class="container">
      <div class="hero">
        <h1>Dan Vokey's Plumbing Services</h1>
        <p>
          Welcome to our customer service portal. This system allows customers to
          register, log in, and submit plumbing service or quote requests online.
        </p>
      </div>

      <div class="info-card">
        <h2 class="section-title">Customer Service Portal</h2>
        <p class="subtitle">
          Submit plumbing issues, request quotes, and track your service requests in one place.
        </p>

        <% if (user) { %>
          <p class="user-badge">Logged in as <%= user.username %></p>
          <div class="button-row">
            <a class="btn btn-primary" href="/dashboard">Go to Dashboard</a>
            <a class="btn btn-secondary" href="/my-requests">My Requests</a>
            <a class="btn btn-danger" href="/logout">Logout</a>
          </div>
        <% } else { %>
          <div class="button-row">
            <a class="btn btn-primary" href="/register">Register</a>
            <a class="btn btn-secondary" href="/login">Login</a>
          </div>
        <% } %>
      </div>

      <p class="footer-note">
        Built as a full-stack service request system for a local Kingston business.
      </p>
    </div>
  </div>
</body>
</html>