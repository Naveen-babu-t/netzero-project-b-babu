<!DOCTYPE html>
<html>
<head>
  <title>Dashboard</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <h2>Dashboard</h2>
    <p>Welcome, <strong><%= user.username %></strong></p>

    <h3>Submit a Service Request</h3>

    <form method="POST" action="/requests">
      <label>Service Type</label>
      <select name="service_type" required>
        <option value="">Select a service</option>
        <option value="Leak Repair">Computer Repair</option>
        <option value="Drain cleaning">Home Security Setup</option>
        <option value="Emergency Plumbing">Tutoring</option>
        <option value="Quote Request">AV Installation</option>
      </select>

      <label>Description</label>
      <textarea name="description" rows="5" required></textarea>

      <button type="submit">Submit Request</button>
    </form>

    <a href="/my-requests">View My Requests</a>
    <a href="/logout">Logout</a>
  </div>
</body>
</html>